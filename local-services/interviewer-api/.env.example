# Preferred backend engine.
# local_primary:
#   Ollama-backed local instruct model, tried first
# nanogpt_backup:
#   owned local Transformer checkpoint, tried first if selected here
# heuristic_dev:
#   deterministic fallback for tests/dev
AITT_PRIMARY_ENGINE=local_primary

# Runtime DB path for persisted content/session state.
AITT_INTERVIEWER_DB_PATH=./runtime/behavioral_content.db

# Optional absolute override for the source behavioral content directory.
# Leave unset to use the repo default under local_model/data/behavioral_interview.
# AITT_BEHAVIORAL_DATA_DIR=C:\path\to\AITT\local_model\data\behavioral_interview

# Ollama settings for the primary engine.
AITT_OLLAMA_MODEL=qwen2.5:1.5b-instruct-q4_0
AITT_OLLAMA_BASE_URL=http://127.0.0.1:11434
AITT_OLLAMA_TIMEOUT=90
