# This repo is split into workspace-local env files.
# Do not rely on a root `.env` for runtime behavior unless you wire that in yourself.

# Frontend app envs live in:
#   aitt/.env.local
AITT_INTERVIEWER_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend interviewer service envs live in:
#   local-services/interviewer-api/.env
AITT_PRIMARY_ENGINE=local_primary
AITT_INTERVIEWER_DB_PATH=./runtime/behavioral_content.db
AITT_OLLAMA_MODEL=qwen2.5:1.5b-instruct-q4_0
AITT_OLLAMA_BASE_URL=http://127.0.0.1:11434
AITT_OLLAMA_TIMEOUT=90

# Optional only if you want to override the default data source directory:
# AITT_BEHAVIORAL_DATA_DIR=C:\path\to\AITT\local_model\data\behavioral_interview
